<Page
    x:Class="OpticaPro.Views.PrescriptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:OpticaPro.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="24" Spacing="24">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Gestión de Recetas e Informes Generales" Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock Text="Generación de historial clínico y PDF." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <AutoSuggestBox PlaceholderText="Buscar paciente..." QueryIcon="Find" Width="300" TextChanged="SearchBox_TextChanged"/>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="EmptyState" Spacing="12" Visibility="Collapsed">
                    <Border CornerRadius="8" Padding="40" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center" Spacing="16">
                            <Ellipse Width="60" Height="60" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                            <FontIcon Glyph="&#xE721;" FontSize="24" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,-42,0,0"/>
                            <TextBlock Text="No hay pacientes registrados." FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ListView x:Name="PrescriptionsList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderDisplayItem">
                            <Border Margin="0,0,0,12" CornerRadius="8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Width="48" Height="48" Fill="{ThemeResource SystemAccentColorLight2}"/>
                                    <FontIcon Glyph="&#xE95E;" FontSize="20" Foreground="{ThemeResource SystemAccentColorDark1}"/>

                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind PatientName}" FontWeight="SemiBold" FontSize="16"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Frame}" FontSize="12" Foreground="Gray"/>
                                            <TextBlock Text="|" FontSize="12" Foreground="Gray"/>
                                            <TextBlock Text="{x:Bind Date}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="2" VerticalAlignment="Center" Margin="0,0,24,0" Background="{x:Bind StatusColorBrush}" CornerRadius="4" Padding="8,4" Opacity="0.2">
                                        <TextBlock Text="{x:Bind Status}" FontSize="12" Foreground="Black" FontWeight="SemiBold" Opacity="1"/>
                                    </Border>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                        <Button Click="PrintFullHistory_Click" Tag="{x:Bind}" ToolTipService.ToolTip="Generar PDF Historial" Padding="8">
                                            <FontIcon Glyph="&#xE749;" FontSize="16" Foreground="{ThemeResource SystemAccentColorDark1}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="PrintingHost" Opacity="0" IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </Grid>
</Page>